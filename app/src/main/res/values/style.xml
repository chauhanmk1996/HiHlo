<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="BottomSheetTopRoundedDialog" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/bottomSheetStyleTopRoundedWrapper</item>
    </style>

    <style name="bottomSheetStyleTopRoundedWrapper" parent="Widget.Design.BottomSheet.Modal">
        <item name="behavior_autoShrink">true</item>
        <item name="android:background">@drawable/top_round_32</item>
        <item name="android:animateLayoutChanges">false</item>
    </style>

    <style name="buttonStyle" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/dp_48</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/dp_16</item>
        <item name="android:paddingHorizontal">@dimen/dp_24</item>
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:background">@drawable/button_bg</item>
    </style>

    <style name="editTextHeading" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/dp_20</item>
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/dp_14</item>
    </style>

    <style name="editTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/dp_48</item>
        <item name="android:layout_marginTop">@dimen/dp_16</item>
        <item name="android:background">@drawable/edit_text_bg</item>
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:singleLine">true</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingHorizontal">@dimen/dp_12</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/color_BFBBBB</item>
        <item name="android:textSize">@dimen/dp_16</item>
        <item name="android:imeOptions">actionNext</item>
    </style>

</resources>