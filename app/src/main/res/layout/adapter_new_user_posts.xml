<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data class="AdapterNewUserPostBinding">

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="3dp"
        android:background="@color/screen_background_black">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/userDetailsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/userImageCardView"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/gredient_circle"
                android:padding="4dp"
                app:cardCornerRadius="80dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/inner_card"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="50dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/black"
                    app:strokeWidth="0dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/userImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/sample_profile" />

                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/onlineStatusImage"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginEnd="0.5dp"
                android:layout_marginBottom="4dp"
                android:src="@drawable/online_status_green"
                app:layout_constraintBottom_toBottomOf="@+id/userImageCardView"
                app:layout_constraintEnd_toEndOf="@id/userImageCardView" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/nameLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_12"
                app:layout_constraintBottom_toBottomOf="@+id/userImageCardView"
                app:layout_constraintEnd_toStartOf="@+id/followButtonLayout"
                app:layout_constraintStart_toEndOf="@+id/userImageCardView"
                app:layout_constraintTop_toTopOf="@+id/userImageCardView">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/userName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/manrope_semibold"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="@color/white"
                    android:textSize="13dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Isha_00" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/verifiedNameTick"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/verified_tick"
                    app:layout_constraintBottom_toBottomOf="@id/userName"
                    app:layout_constraintStart_toEndOf="@+id/userName"
                    app:layout_constraintTop_toTopOf="@+id/userName" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/userLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/manrope_regular"
                    android:maxLines="1"
                    android:text="Jaipur, India"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/userName" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/followButtonLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@+id/userImageCardView"
                app:layout_constraintEnd_toStartOf="@id/sideOptions"
                app:layout_constraintTop_toTopOf="@+id/userImageCardView">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/followButtonImage"
                    android:layout_width="63dp"
                    android:layout_height="32dp"
                    android:src="@drawable/follow_button_reel" />

            </LinearLayout>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/sideOptions"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/more_option"
                app:backgroundTint="@color/theme"
                app:layout_constraintBottom_toBottomOf="@id/nameLayout"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/nameLayout" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/captionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toBottomOf="@+id/userImageCardView">

                <!-- Collapsed version -->
                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/captionCollapsed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_16"
                    android:ellipsize="end"
                    android:fontFamily="@font/manrope_regular"
                    android:maxLines="1"
                    android:textColor="@color/white_FEFEFF"
                    android:textSize="13dp"
                    app:layout_constraintEnd_toStartOf="@+id/moreLessText"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="@string/choose_photos_that_capture_your_personality_and_the_things_you_love_to_do" />

                <!-- "More" button -->
                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/moreLessText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginTop="0dp"
                    android:layout_marginEnd="@dimen/dp_8"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/manrope_bold"
                    android:paddingStart="0dp"
                    android:paddingTop="@dimen/dp_8"
                    android:paddingEnd="@dimen/dp_8"
                    android:paddingBottom="@dimen/dp_8"
                    android:text="More"
                    android:textColor="@color/theme"
                    android:textSize="13dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@id/captionCollapsed"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/captionCollapsed" />

                <!-- Expanded version (single TextView) -->
                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/captionExpanded"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:fontFamily="@font/manrope_regular"
                    android:textColor="@color/white_FEFEFF"
                    android:textSize="13dp"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="@string/choose_photos_that_capture_your_personality_and_the_things_you_love_to_do" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/postImage"
            android:layout_width="match_parent"
            android:layout_height="550dp"
            android:layout_marginTop="10dp"
            android:adjustViewBounds="true"
            android:src="@drawable/sample_computer_image"
            app:layout_constraintBottom_toBottomOf="@id/likeLayout"
            app:layout_constraintTop_toBottomOf="@id/userDetailsLayout" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/likeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/screen_background_black"
            android:paddingTop="8dp"
            android:paddingBottom="1dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/actionsGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:id="@+id/btn_Like"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/likeImage"
                        android:layout_width="28dp"
                        android:layout_height="32dp"
                        android:src="@drawable/btn_heart_normal" />

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/likesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white" />

                <LinearLayout
                    android:id="@+id/btn_Comment"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/commentImage"
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/comment_icon_white" />

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/commentsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/shareImage"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="20dp"
                    android:padding="2dp"
                    android:src="@drawable/share_icon_white" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/giftImage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:padding="2.3dp"
                android:src="@drawable/giftbold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.3dp"
            android:background="@color/gray_303030"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>