<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/screen_background_black"
        tools:context=".ui.signup.fragment.EmailFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_semibold"
                android:paddingHorizontal="10dp"
                android:text="Change Password"
                android:textColor="@color/white"
                android:textSize="22sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/backButton"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:src="@drawable/back_button_pink"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>


        <ScrollView
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="10dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/inner_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/grey_outline_without_border"
                    android:layout_marginHorizontal="20dp"
                    android:padding="20dp"
                    tools:ignore="MissingConstraints">

                    <TextView
                        android:id="@+id/tvSetNewPasswordDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Change your password. Ensure it differs from previous ones for security"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:layout_marginTop="15dp"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="MissingConstraints" />


                    <!-- Password Label -->
                    <TextView
                        android:id="@+id/oldPasswordLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Old Password"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintTop_toBottomOf="@id/tvSetNewPasswordDesc"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Password Layout -->

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/oldPasswordLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/background_10dp_corner_round"
                        android:backgroundTint="@color/black"                     app:layout_constraintTop_toBottomOf="@id/oldPasswordLabel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <EditText
                            android:id="@+id/oldPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:fontFamily="@font/manrope_regular"
                            android:hint="Enter old password"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:maxLength="20"
                            android:maxLines="1"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="13dp"
                            android:textColor="@color/white"
                            android:textColorHint="@color/textDescColor"
                            android:textSize="16sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/oldPasswordToggle"
                            app:layout_constraintHorizontal_bias="0.363"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_bias="0.0" />

                        <ImageView
                            android:id="@+id/oldPasswordToggle"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="20dp"
                            app:tint="@color/white"
                            android:src="@drawable/close_eye_2"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/passwordLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:text="New Password"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintTop_toBottomOf="@id/oldPasswordLayout"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Password Layout -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/passwordLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/background_10dp_corner_round"
                        android:backgroundTint="@color/black"                     app:layout_constraintTop_toBottomOf="@id/passwordLabel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <EditText
                            android:id="@+id/password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/enter_passowrd"
                            android:inputType="textPassword"
                            android:maxLength="20"
                            android:maxLines="1"
                            android:imeOptions="actionDone"
                            android:paddingVertical="13dp"
                            android:paddingHorizontal="8dp"
                            android:fontFamily="@font/manrope_regular"
                            android:textSize="16sp"
                            android:textColor="@color/white"
                            android:textColorHint="@color/textDescColor"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/password_toggle" />

                        <ImageView
                            android:id="@+id/password_toggle"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="20dp"
                            app:tint="@color/white"
                            android:src="@drawable/close_eye_2"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Password Label -->
                    <TextView
                        android:id="@+id/cnfPwdLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:text="@string/confirm_new_password"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintTop_toBottomOf="@id/passwordLayout"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Password Layout -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/CnfPasswordLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/background_10dp_corner_round"
                        android:backgroundTint="@color/black"                     app:layout_constraintTop_toBottomOf="@id/cnfPwdLabel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <EditText
                            android:id="@+id/etCnfpassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/enter_passowrd"
                            android:inputType="textPassword"
                            android:maxLength="20"
                            android:maxLines="1"
                            android:imeOptions="actionDone"
                            android:paddingVertical="13dp"
                            android:paddingHorizontal="8dp"
                            android:fontFamily="@font/manrope_regular"
                            android:textSize="16sp"
                            android:textColor="@color/white"
                            android:textColorHint="@color/textDescColor"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/cnfPwdToggle" />

                        <ImageView
                            android:id="@+id/cnfPwdToggle"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="20dp"
                            app:tint="@color/white"
                            android:src="@drawable/close_eye_2"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChangePassword"
                    style="@style/MyButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:layout_marginHorizontal="20dp"
                    android:paddingVertical="12dp"
                    android:text="Change Password"
                    android:textSize="18sp"
                    android:fontFamily="@font/manrope_medium"
                    app:layout_constraintTop_toBottomOf="@id/inner_layout"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>