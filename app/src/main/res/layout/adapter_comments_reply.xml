<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_marginStart="0dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/parent_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:ignore="MissingConstraints"
            android:paddingTop="5dp"
            android:paddingStart="10dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/userImageCardView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/gredient_circle"
                app:cardCornerRadius="80dp"
                android:padding="3dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.card.MaterialCardView

                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="50dp"
                    android:id="@+id/inner_card"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:id="@+id/userImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/sample_profile" />
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/name"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginTop="-3dp"
                android:layout_marginEnd="20dp"
                android:textSize="12sp"
                android:fontFamily="@font/manrope_semibold"
                android:textColor="@color/white"
                android:text="Abhaysharma"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/userImageCardView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp" />

            <ImageView
                android:id="@+id/verifiedNameTick"
                android:layout_marginStart="5dp"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginTop="2.5dp"
                android:src="@drawable/verified_tick"
                app:layout_constraintStart_toEndOf="@+id/name"
                app:layout_constraintTop_toTopOf="@+id/name"
                app:layout_constraintBottom_toBottomOf="@+id/name" />

            <TextView
                android:id="@+id/userId"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginEnd="20dp"
                android:textSize="11sp"
                android:fontFamily="@font/manrope_regular"
                android:textColor="@color/white_40"
                android:text="Abhay_06"
                app:layout_constraintTop_toBottomOf="@id/name"
                app:layout_constraintStart_toEndOf="@id/userImageCardView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp" />

            <TextView
                android:visibility="gone"
                android:id="@+id/userLocation"
                app:layout_constraintEnd_toEndOf="parent"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginEnd="20dp"
                android:textSize="13sp"
                android:fontFamily="@font/manrope_regular"
                android:textColor="@color/white_40"
                android:text="Abhaysharma"
                app:layout_constraintTop_toBottomOf="@id/userId"
                app:layout_constraintStart_toEndOf="@id/userImageCardView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp" />

            <TextView
                android:id="@+id/comment"
                app:layout_constraintEnd_toEndOf="parent"
                android:maxLines="5"
                android:layout_marginEnd="20dp"
                android:textSize="13.5sp"
                android:fontFamily="@font/manrope_regular"
                android:textColor="@color/white"
                android:text="Nature at its best."
                app:layout_constraintTop_toBottomOf="@id/userLocation"
                app:layout_constraintStart_toEndOf="@id/userImageCardView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/action_lay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toBottomOf="@id/comment"
                app:layout_constraintStart_toEndOf="@id/userImageCardView">

                <TextView
                    android:id="@+id/reply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reply"
                    android:textSize="12sp"
                    android:textColor="@color/theme"
                    android:fontFamily="@font/manrope_semibold"
                    android:layout_marginStart="10dp"
                    tools:ignore="MissingConstraints"
                    android:visibility="gone"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>